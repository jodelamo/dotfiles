# Keep secrets in `.localrc`
if [[ -a ~/.localrc ]] then
  source ~/.localrc
fi

# Shortcut to this dotfiles path is $ZSH
export ZSH=~/.dotfiles

# Project folder
export PROJECTS=~/Dev

# Ensure cache directory exists (used by version manager init caching)
[[ -d "$ZSH_CACHE_DIR" ]] || mkdir -p "$ZSH_CACHE_DIR"

# Deduplicate PATH entries automatically
typeset -U path

# A better `mv`
autoload -U zmv

# All of our zsh files
typeset -U config_files
config_files=($ZSH/**/*.zsh)

# Load the path files
for file in ${(M)config_files:#*/path.zsh}; do
  source $file
done

# Load everything but the path and completion files
for file in ${${config_files:#*/path.zsh}:#*/completion.zsh}; do
  source $file
done

# Initialize autocomplete AFTER fpath is fully set up
autoload -Uz compinit
if [[ -f "$ZSH_CACHE_DIR/.zcompdump" && "$ZSH_CACHE_DIR/.zcompdump"(#qN.mh+24) == "" ]]; then
  # Cache is less than 24h old, use it without regenerating
  compinit -C -d "$ZSH_CACHE_DIR/.zcompdump"
else
  compinit -d "$ZSH_CACHE_DIR/.zcompdump"
fi
zmodload -i zsh/complist

# Load every completion after autocomplete loads
for file in ${(M)config_files:#*/completion.zsh}; do
  source $file
done

unset config_files

# Set up fzf key bindings and fuzzy completion (cached)
local fzf_cache="$ZSH_CACHE_DIR/fzf_init.zsh"
if [[ ! -f "$fzf_cache" || "$commands[fzf]" -nt "$fzf_cache" ]]; then
  fzf --zsh > "$fzf_cache" 2>/dev/null
fi
source "$fzf_cache"

# Syntax highlighting (direct source, no plugin manager needed)
if [[ "$(uname)" == "Darwin" ]]; then
  source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
elif [[ "$(uname)" == "Linux" ]]; then
  source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# opencode
export PATH=/home/jorum/.opencode/bin:$PATH

export NVM_DIR="$HOME/.config/nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
