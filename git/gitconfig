[color]
  ui = auto
[core]
  excludesfile = ~/.gitignore
  editor = nvim
  autocrlf = input
  ignorecase = false
  pager = delta
[user]
  name = Joacim de la Motte
  email = joacim.delamotte@gmail.com
[alias]
  co = checkout
  ci = commit
  cm = commit -m
  st = status
  br = branch
  aa = add --all
  cl = clean -dxf
  type = cat-file -t
  dump = cat-file -p
  dft = difftool
  dlog = "!f() { : git log ; GIT_EXTERNAL_DIFF=difft git log -p --ext-diff $@; }; f"
[push]
  autoSetupRemote = true
[pull]
  rebase = true
[fetch]
  prune = true
[init]
  defaultBranch = main
[rebase]
  autosquash = true
  autostash = true
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  light = false
  line-numbers = true
[merge]
  conflictstyle = zdiff3
[diff]
  tool = difftastic
  algorithm = histogram
[difftool]
  prompt = false
[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"
[pager]
  difftool = true
